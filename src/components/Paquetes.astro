---
// Paquetes - Planes y servicios adicionales
---
<section id="paquetes" class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Nuestros Paquetes</h2>
      <p class="text-gray-600">Elige el que mejor se adapte a tu negocio</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Básico -->
      <div class="bg-white rounded-2xl shadow-lg p-8 border-2 border-transparent hover:border-orange-500 transition">
        <div class="flex justify-between items-start mb-6">
          <div>
            <h3 class="text-2xl font-bold">Básico</h3>
            <p class="text-gray-500">Para negocios que inician</p>
          </div>
          <div class="text-right">
            <span class="text-sm text-gray-500">desde</span>
            <p class="text-3xl font-bold text-orange-600">$80</p>
          </div>
        </div>
        <ul class="space-y-4 mb-8">
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Landing page profesional
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Catálogo de productos (hasta 20)
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Botón WhatsApp flotante
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Mapa de ubicación
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Diseño responsive (móvil)
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Panel de admin editable
          </li>
        </ul>
        <p class="text-gray-500 text-sm mb-6">Mantenimiento desde <strong class="text-gray-800">$15/mes</strong></p>
        <a href="#contacto" class="block text-center bg-gray-100 text-gray-800 font-semibold py-3 rounded-lg hover:bg-orange-600 hover:text-white transition">
          Solicitar Información
        </a>
      </div>

      <!-- Profesional -->
      <div class="bg-white rounded-2xl shadow-lg p-8 border-2 border-orange-500 relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-orange-500 text-white px-4 py-1 rounded-full text-sm font-medium">
          Más popular
        </div>
        <div class="flex justify-between items-start mb-6">
          <div>
            <h3 class="text-2xl font-bold">Profesional</h3>
            <p class="text-gray-500">Para negocios que crecen</p>
          </div>
          <div class="text-right">
            <span class="text-sm text-gray-500">desde</span>
            <p class="text-3xl font-bold text-orange-600">$200</p>
          </div>
        </div>
        <ul class="space-y-4 mb-8">
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Todo lo del Básico
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Dominio propio (.com/.ar)
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Google My Business configurado
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Google Analytics + reportes
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Optimización SEO local
          </li>
          <li class="flex items-center gap-3">
            <span class="text-green-500">✓</span> Capacitación incluida
          </li>
        </ul>
        <p class="text-gray-500 text-sm mb-6">Mantenimiento desde <strong class="text-gray-800">$30/mes</strong></p>
        <a href="#contacto" class="block text-center bg-orange-600 text-white font-semibold py-3 rounded-lg hover:bg-orange-700 transition">
          Solicitar Información
        </a>
      </div>
    </div>

    <!-- Servicios adicionales -->
    <div class="mt-16">
      <h3 class="text-xl font-bold text-center mb-8">También atendemos negocios con sitio existente</h3>
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-white rounded-xl p-6 shadow">
          <h4 class="font-bold mb-2">SEO + Analytics</h4>
          <p class="text-gray-600 text-sm mb-4">Google Analytics, Search Console, Google My Business, reportes mensuales.</p>
          <p class="text-orange-600 font-bold">desde $20/mes</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow">
          <h4 class="font-bold mb-2">Mantenimiento</h4>
          <p class="text-gray-600 text-sm mb-4">Actualizaciones, backups, cambios menores, monitoreo de disponibilidad.</p>
          <p class="text-orange-600 font-bold">desde $15/mes</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow">
          <h4 class="font-bold mb-2">Combo</h4>
          <p class="text-gray-600 text-sm mb-4">SEO + Analytics + Mantenimiento juntos.</p>
          <p class="text-orange-600 font-bold">desde $30/mes</p>
        </div>
      </div>
    </div>
  </div>
</section>