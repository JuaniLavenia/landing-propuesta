---
// Contacto - Formulario + WhatsApp
---
<section id="contacto" class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-xl p-8">
      <h2 class="text-3xl font-bold text-center mb-4">¿Hablamos?</h2>
      <p class="text-gray-600 text-center mb-8">Dejá tu datos y te contactamos en 24hs.</p>

      <form class="space-y-4" action="https://formspree.io/f/xpwzgjzp" method="POST">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nombre del negocio</label>
          <input type="text" name="negocio" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tu nombre</label>
          <input type="text" name="nombre" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp</label>
          <input type="tel" name="whatsapp" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">¿Qué necesitás?</label>
          <select name="servicio" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent">
            <option>Nuevo sitio web</option>
            <option>SEO + Analytics para sitio existente</option>
            <option>Mantenimiento</option>
            <option>Otro</option>
          </select>
        </div>
        <button type="submit" class="w-full bg-orange-600 text-white font-semibold py-4 rounded-lg hover:bg-orange-700 transition">
          Enviar Solicitud
        </button>
      </form>

      <p class="text-center text-gray-500 text-sm mt-6">O escribinos directamente por WhatsApp</p>
      <div class="text-center mt-4">
        <a href="https://wa.me/5491112345678" class="inline-flex items-center gap-2 text-green-600 font-semibold hover:underline">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
          Chatear por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>