---
// Landing page para DigitalLocal
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import Paquetes from '../components/Paquetes.astro';
import PorQue from '../components/PorQue.astro';
import Proceso from '../components/Proceso.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Digitalizá tu Negocio Local | Presencia Online Profesional</title>
  <meta name="description" content="Sitios web profesionales para negocios locales. Tu negocio online en menos de 24hs.">
</head>
<body class="font-sans text-gray-800">
  <Header />
  <main>
    <Hero />
    <Servicios />
    <Paquetes />
    <PorQue />
    <Proceso />
    <Contacto />
  </main>
  <Footer />
</body>
</html>